# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# scripts: manual text extraction cache
.manuals-text/

# scripts: progress/rollback/report files
.match-signs-v2-progress.json
.match-signs-v2-*-progress.json
.verify-answers-*-progress.json
.verify-answers-*-report.json
.verify-answers-*-rollback.json
.expand-images-progress.json
.expand-images-report.json
.verify-images-progress.json
.verify-images-*-progress.json
.verify-images-strict-*-progress.json
.download-manuals-progress.json
.write-explanations-*-progress.json
